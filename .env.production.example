###############################################################################
# OpenClaw Social Media Automation — Production Environment
#
# Copy to .env.production and fill in your values:
#   cp .env.production.example .env.production
#
# FRAMEWORK RESPONSIBILITY:
#   Dashboard  = User interface (upload, configure, monitor)
#   n8n        = Nervous system (orchestration, APIs, scheduling)
#   OpenClaw   = Brain (AI content generation, scrum planning)
#   Media Worker = Hands (FFmpeg video processing)
###############################################################################

# ─── Server ────────────────────────────────────────────────────────────────
DOMAIN=yourdomain.com
TZ=Europe/Berlin

# ─── Security ──────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME_to_random_32_chars
OPENCLAW_GATEWAY_TOKEN=CHANGE_ME_to_random_64_chars
HOOKS_TOKEN=CHANGE_ME_to_random_64_chars
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME

# ─── AI Providers (OpenClaw — the BRAIN) ───────────────────────────────────
# At least one is required. Anthropic recommended for best results.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# ─── Social Media APIs (n8n — the NERVOUS SYSTEM) ─────────────────────────
# These are used by n8n workflows, NOT by OpenClaw.

# Meta (Facebook + Instagram)
# Get from: https://developers.facebook.com/apps/
META_APP_ID=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=
# Instagram Business Account ID (linked to Facebook Page)
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# TikTok
# Get from: https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# YouTube
# Get from: https://console.cloud.google.com/ (YouTube Data API v3)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# WhatsApp Business
# Get from: https://business.facebook.com/ → WhatsApp
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# ─── OpenClaw Config ──────────────────────────────────────────────────────
OPENCLAW_CONFIG_DIR=/home/node/.openclaw
OPENCLAW_WORKSPACE_DIR=/home/node/.openclaw/workspace
OPENCLAW_IMAGE=openclaw:local

# ─── Media Worker ─────────────────────────────────────────────────────────
MEDIA_WORKER_PORT=3001
MEDIA_MAX_FILE_SIZE=500mb
# Default watermark position: bottom-right
WATERMARK_POSITION=bottom-right
WATERMARK_OPACITY=0.7
